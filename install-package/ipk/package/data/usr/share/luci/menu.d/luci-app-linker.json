{
	"admin/services/linker": {
		"title": "Linker",
		"order": 90,
		"action": {
			"type": "alias",
			"path": "admin/services/linker/manage"
		},
		"depends": {
			"acl": [ "luci-app-linker" ],
			"fs": {
				"/etc/init.d/linker": "executable"
			}
		}
	},

	"admin/services/linker/stop": {
		"title": "停止",
		"order": 10,
		"action": {
			"type": "function",
			"module": "luci.controller.linker",
			"function": "action_stop"
		}
	},

	"admin/services/linker/start": {
		"title": "启动",
		"order": 20,
		"action": {
			"type": "function",
			"module": "luci.controller.linker",
			"function": "action_start"
		}
	},

	"admin/services/linker/manage": {
		"title": "管理页面",
		"order": 30,
		"action": {
			"type": "function",
			"module": "luci.controller.linker",
			"function": "action_manage"
		}
	}
}
